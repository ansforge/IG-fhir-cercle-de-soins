         fhir:link <https://interop.esante.gouv.fr/ig/fhir/cds/StructureDefinition/cds-bundle-transaction-creation> ;
         fhir:reference [ fhir:v "StructureDefinition/cds-bundle-transaction-creation" ]
       ] ;
       fhir:name [ fhir:v "CDS Bundle Transaction Creation Profile" ] ;
       fhir:description [ fhir:v "Profil défini dans le volet de Gestion du Cercle de Soins (flux 1c) pour créer un cercle de soins selon l’option Transaction.\nIl s'agit d'un bundle de type `transaction` permettant d'organiser le contenu du flux de création d'un cercle de soins." ] ;
