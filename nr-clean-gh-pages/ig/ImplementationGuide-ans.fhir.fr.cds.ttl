       ] ;
       fhir:ImplementationGuide.definition.resource.name [ fhir:value "CDS Bundle Response Recherche Profile" ] ;
       fhir:ImplementationGuide.definition.resource.description [ fhir:value "Profil « Bundle » de type « searchset » encapsulant une collection de 0, une ou plusieurs ressources « CareTeam » répondant aux critères de recherche. Les ressources référencées par les ressources CareTeam retournées sont aussi dans le Bundle s’il a été demandé de les inclure dans la requête GET." ] ;
       fhir:ImplementationGuide.definition.resource.exampleBoolean [ fhir:value "false"^^xsd:boolean ]
     ], [
