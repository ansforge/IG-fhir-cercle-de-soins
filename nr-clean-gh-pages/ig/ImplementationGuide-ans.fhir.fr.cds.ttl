       ] ;
       fhir:ImplementationGuide.definition.resource.name [ fhir:value "CDS Bundle Transaction Creation Profile" ] ;
       fhir:ImplementationGuide.definition.resource.description [ fhir:value "Profil défini dans le volet de Gestion du Cercle de Soins (flux 1c) pour créer un cercle de soins selon l’option Transaction.\nIl s'agit d'un bundle de type `transaction` permettant d'organiser le contenu du flux de création d'un cercle de soins." ] ;
       fhir:ImplementationGuide.definition.resource.exampleBoolean [ fhir:value "false"^^xsd:boolean ]
     ], [
