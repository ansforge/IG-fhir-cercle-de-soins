<?xml version="1.0" ?>

<xliff xmlns="urn:oasis:names:tc:xliff:document:2.0" version="2.0">
  <file source-language="fr" target-language="en" id="Organization-cds-organization-example" original="Resource Organization-cds-organization-example" datatype="KEYVALUEJSON">
    <body>
      <trans-unit id="Organization-cds-organization-example" resname="Coding.display">
             <notes>
               <note id="n1">A representation of the meaning of the code in the system, following the rules of the system.</note>
             </notes>
        <source>Médical</source>
        <target></target>
      </trans-unit>
      <trans-unit id="Organization-cds-organization-example" resname="Organization.name">
             <notes>
               <note id="n1">A name associated with the organization.</note>
             </notes>
        <source>Cabinet médical CC CC</source>
        <target></target>
      </trans-unit>
      <trans-unit id="Organization-cds-organization-example" resname="Organization.alias">
             <notes>
               <note id="n1">A list of alternate names that the organization is known as, or was known as in the past.</note>
             </notes>
        <source>CC CC Rennes</source>
        <target></target>
      </trans-unit>
      <trans-unit id="Organization-cds-organization-example" resname="Address.line">
             <notes>
               <note id="n1">This component contains the house number, apartment number, street name, street direction,  P.O. Box number, delivery hints, and similar address information.</note>
             </notes>
        <source>12 rue du paris</source>
        <target></target>
      </trans-unit>
      <trans-unit id="Organization-cds-organization-example" resname="Address.city">
             <notes>
               <note id="n1">The name of the city, town, suburb, village or other community or delivery center.</note>
             </notes>
        <source>Rennes</source>
        <target></target>
      </trans-unit>
      <trans-unit id="Organization-cds-organization-example" resname="Address.postalCode">
             <notes>
               <note id="n1">A postal code designating a region defined by the postal service.</note>
             </notes>
        <source>35000</source>
        <target></target>
      </trans-unit>
      <trans-unit id="Organization-cds-organization-example" resname="Address.country">
             <notes>
               <note id="n1">Country - a nation as commonly understood or generally accepted.</note>
             </notes>
        <source>99100</source>
        <target></target>
      </trans-unit>
    </body>
  </file>
